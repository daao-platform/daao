# DAAO Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Generated by: bash scripts/setup.sh
# Or copy this to .env and fill in the values manually.
# ─────────────────────────────────────────────────────────────────────

# ============================================================================
# Security (REQUIRED)
# ============================================================================

# JWT signing secret — used for internal API token validation.
# Must be a long random string.  The setup script generates one for you.
JWT_SECRET=CHANGE-ME-TO-A-REAL-SECRET

# ============================================================================
# Database (REQUIRED)
# ============================================================================

# Password for the PostgreSQL daao user.
POSTGRES_PASSWORD=CHANGE-ME-TO-A-REAL-PASSWORD

# ============================================================================
# Owner Account (optional)
# ============================================================================

# Email for the initial admin user, created on first startup.
# Leave empty to skip — you can create users later via the API.
DAAO_OWNER_EMAIL=

# Password for the owner. If empty, a random password is printed
# to the Nexus log on first boot (like Grafana).
# DAAO_OWNER_PASSWORD=

# ============================================================================
# Deployment (optional)
# ============================================================================

# Port for the Cockpit web dashboard (default: 8081)
COCKPIT_PORT=8081

# Host directory for session recording files (default: ./data/recordings)
# DAAO_RECORDINGS_DIR=./data/recordings
